<!DOCTYPE html>
<html lang="kk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Анашыма — Туған күн құтты болсын!</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,600&family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
<style>
  :root{
    --plum: #2b1023;
    --plum-2: #3d1530;
    --wine: #7a2142;
    --blush: #f3c7d4;
    --blush-2: #f8dde4;
    --gold: #d8ad55;
    --gold-2: #f0d698;
    --cream: #fbf3ec;
    --shadow: rgba(0,0,0,.35);
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background: radial-gradient(circle at 50% 0%, var(--plum-2), var(--plum) 65%);
    font-family:'Nunito', sans-serif;
    color: var(--cream);
    overflow-x:hidden;
    min-height:100vh;
    position:relative;
  }

  /* ---------- INTRO CURTAIN ---------- */
  #curtain{
    position:fixed; inset:0; z-index:999;
    display:flex; align-items:center; justify-content:center;
    pointer-events:none;
  }
  .curtain-half{
    position:absolute; top:0; bottom:0; width:52%;
    background: linear-gradient(135deg, var(--wine), var(--plum) 70%);
    box-shadow: 0 0 80px var(--shadow) inset;
  }
  .curtain-left{ left:0; border-right:3px solid var(--gold);
    animation: openLeft 1.6s 1.1s cubic-bezier(.77,0,.18,1) forwards; }
  .curtain-right{ right:0; border-left:3px solid var(--gold);
    animation: openRight 1.6s 1.1s cubic-bezier(.77,0,.18,1) forwards; }
  @keyframes openLeft{ to{ transform: translateX(-100%);} }
  @keyframes openRight{ to{ transform: translateX(100%);} }

  #intro-text{
    position:relative; z-index:1000; text-align:center;
    font-family:'Playfair Display', serif;
    animation: fadeOutText .6s .9s forwards;
  }
  #intro-text .line1{
    display:block; font-size: clamp(20px,4vw,32px); letter-spacing:.12em;
    color: var(--gold-2); text-transform:uppercase; opacity:0;
    animation: popIn .7s .1s forwards;
  }
  #intro-text .line2{
    display:block; font-size: clamp(34px,7vw,64px); font-weight:700; color:var(--cream);
    opacity:0; margin-top:8px;
    animation: popIn .8s .45s forwards;
  }
  @keyframes popIn{
    0%{ opacity:0; transform: scale(.6) translateY(30px); filter:blur(6px);}
    60%{ opacity:1; transform: scale(1.08) translateY(0); filter:blur(0);}
    100%{ opacity:1; transform: scale(1) translateY(0);}
  }
  @keyframes fadeOutText{ to{ opacity:0; visibility:hidden;} }

  #confetti-burst{ position:fixed; inset:0; z-index:998; pointer-events:none; }
  .confetti{
    position:absolute; top:45%; left:50%; width:10px; height:14px; opacity:0;
    animation: burst 1.4s ease-out forwards;
  }
  @keyframes burst{
    0%{ opacity:1; transform: translate(-50%,-50%) rotate(0deg) scale(.5); }
    100%{ opacity:0; transform: translate(var(--tx), var(--ty)) rotate(var(--rot)) scale(1); }
  }

  /* ---------- AMBIENT BACKGROUND ---------- */
  #bg-field{
    position:fixed; inset:0; z-index:0; pointer-events:none; overflow:hidden;
  }
  .petal, .spark{
    position:absolute; top:-40px; will-change: transform;
    animation-name: fall; animation-timing-function: linear; animation-iteration-count: infinite;
  }
  @keyframes fall{
    to{ transform: translateY(110vh) translateX(var(--drift)) rotate(var(--spin)); }
  }
  .spark{
    width:4px; height:4px; border-radius:50%; background: var(--gold-2);
    box-shadow:0 0 6px 1px var(--gold-2);
    animation-name: twinkleFall;
  }
  @keyframes twinkleFall{
    0%{ opacity:0; transform: translateY(0) translateX(0); }
    10%{ opacity:1;}
    90%{ opacity:1;}
    100%{ opacity:0; transform: translateY(110vh) translateX(var(--drift)); }
  }

  /* ---------- MAIN CONTENT ---------- */
  main{ position:relative; z-index:1; max-width:900px; margin:0 auto; padding: 70px 24px 40px; text-align:center; }

  .eyebrow{
    font-size:13px; letter-spacing:.35em; text-transform:uppercase; color: var(--gold-2);
    margin-bottom:18px; opacity:.9;
  }

  /* ---------- PHOTO FRAME ---------- */
  #photo-wrap{
    width: 190px; height: 190px; margin: 0 auto 26px;
    position: relative;
    animation: popIn 1s .3s backwards;
  }
  #photo-frame{
    width:100%; height:100%; border-radius:50%;
    padding:6px;
    background: conic-gradient(from 0deg, var(--gold), var(--blush), var(--gold-2), var(--wine), var(--gold));
    box-shadow: 0 10px 34px rgba(0,0,0,.45), 0 0 0 1px rgba(216,173,85,.4);
    animation: frameGlow 5s ease-in-out infinite;
  }
  @keyframes frameGlow{
    0%,100%{ filter: drop-shadow(0 0 0px rgba(216,173,85,0)); }
    50%{ filter: drop-shadow(0 0 18px rgba(216,173,85,.55)); }
  }
  #photo-inner{
    width:100%; height:100%; border-radius:50%; overflow:hidden;
    background: linear-gradient(160deg, rgba(255,255,255,.08), rgba(255,255,255,.02));
    display:flex; align-items:center; justify-content:center; position:relative;
  }
  #photo-inner img{
    width:100%; height:100%; object-fit:cover; display:none;
  }
  #photo-placeholder{
    display:flex; flex-direction:column; align-items:center; gap:6px;
    color: var(--blush-2); font-size:12px; text-align:center; padding:10px;
  }
  #photo-placeholder .ico{ font-size:34px; opacity:.8; }
  #photo-input{ display:none; }
  #photo-label{
    position:absolute; bottom:2px; right:2px; width:38px; height:38px; border-radius:50%;
    background: linear-gradient(120deg, var(--gold), var(--gold-2));
    display:flex; align-items:center; justify-content:center; font-size:16px; cursor:pointer;
    box-shadow: 0 4px 12px rgba(0,0,0,.4); border:2px solid var(--plum);
    transition: transform .2s ease;
  }
  #photo-label:hover{ transform: scale(1.08); }
  h1{
    font-family:'Playfair Display', serif; font-weight:700;
    font-size: clamp(36px, 6vw, 68px); margin: 0 0 6px;
    color: var(--cream);
    text-shadow: 0 4px 26px rgba(216,173,85,.35);
  }
  h1 span{ color: var(--gold); font-style:italic; }

  .tulip-divider{ display:flex; align-items:center; justify-content:center; gap:14px; margin: 22px 0 30px; }
  .tulip-divider .line{ height:1px; width:70px; background: linear-gradient(90deg, transparent, var(--gold), transparent); }

  .message{
    font-size: clamp(16px, 2.4vw, 19px); line-height:1.85; color: var(--blush-2);
    max-width: 640px; margin: 0 auto 34px; font-weight:400;
  }
  .message strong{ color: var(--gold-2); font-weight:800; }

  .wish-cards{
    display:grid; grid-template-columns: repeat(auto-fit, minmax(190px,1fr));
    gap:16px; margin: 30px 0 50px;
  }
  .wish-card{
    background: linear-gradient(160deg, rgba(255,255,255,.07), rgba(255,255,255,.02));
    border:1px solid rgba(216,173,85,.25);
    border-radius:16px; padding:22px 16px; backdrop-filter: blur(4px);
    transition: transform .35s ease, border-color .35s ease;
  }
  .wish-card:hover{ transform: translateY(-6px); border-color: var(--gold); }
  .wish-card .ico{ font-size:28px; display:block; margin-bottom:10px; }
  .wish-card p{ margin:0; font-size:14.5px; color: var(--blush-2); line-height:1.5; }

  /* ---------- GAME SECTION ---------- */
  .game-wrap{
    margin-top: 20px; border-radius:22px; padding:2px;
    background: linear-gradient(120deg, var(--gold), var(--wine), var(--gold));
  }
  .game-inner{
    background: linear-gradient(180deg, rgba(43,16,35,.92), rgba(61,21,48,.96));
    border-radius:20px; padding: 26px 18px 30px;
  }
  .game-title{ font-family:'Playfair Display', serif; font-size: clamp(22px,3.2vw,30px); margin:0 0 6px; color:var(--gold-2); }
  .game-sub{ font-size:14px; color: var(--blush-2); margin:0 0 18px; opacity:.85; }

  #game-stage{
    position:relative; width:100%; max-width:520px; height:380px; margin:0 auto;
    border-radius:16px; overflow:hidden; cursor:none; touch-action:none;
    background: radial-gradient(circle at 50% 100%, rgba(216,173,85,.15), transparent 60%), var(--plum);
    border:1px solid rgba(216,173,85,.3);
  }
  .falling{
    position:absolute; top:-40px; font-size:26px; user-select:none; pointer-events:none;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,.4));
  }
  #basket{
    position:absolute; bottom:14px; width:64px; height:44px; font-size:38px;
    display:flex; align-items:center; justify-content:center;
    transform: translateX(-50%); pointer-events:none;
  }
  #hud{
    display:flex; justify-content:space-between; max-width:520px; margin: 12px auto 0;
    font-weight:800; font-size:15px; color: var(--gold-2);
  }
  #game-btn{
    margin-top:18px; border:none; cursor:pointer; padding:12px 30px; border-radius:999px;
    background: linear-gradient(120deg, var(--gold), var(--gold-2));
    color: var(--plum); font-weight:800; font-size:15px; letter-spacing:.02em;
    box-shadow: 0 8px 22px rgba(216,173,85,.35);
    transition: transform .2s ease;
  }
  #game-btn:hover{ transform: translateY(-2px) scale(1.03); }

  #game-end{
    position:absolute; inset:0; display:none; align-items:center; justify-content:center; flex-direction:column;
    background: rgba(43,16,35,.92); text-align:center; padding:20px;
  }
  #game-end h3{ font-family:'Playfair Display', serif; font-size:26px; color: var(--gold-2); margin:0 0 8px; }
  #game-end p{ color: var(--blush-2); margin:0 0 16px; font-size:15px; }

  footer{
    position:relative; z-index:1; text-align:center; padding: 30px 20px 50px;
    font-size:13px; color: rgba(248,221,228,.55); letter-spacing:.05em;
  }
  footer .signature{ font-family:'Playfair Display', serif; font-style:italic; font-size:18px; color: var(--gold-2); display:block; margin-bottom:6px; }

  @media (prefers-reduced-motion: reduce){
    .petal, .spark, .confetti, #intro-text .line1, #intro-text .line2{ animation: none !important; }
    .curtain-left, .curtain-right{ animation-duration: .01s !important; }
  }
</style>
</head>
<body>

  <!-- INTRO CURTAIN -->
  <div id="curtain">
    <div class="curtain-half curtain-left"></div>
    <div class="curtain-half curtain-right"></div>
    <div id="intro-text">
      <span class="line1">Ерекше бір күн</span>
      <span class="line2">Анашым үшін 🌷</span>
    </div>
  </div>
  <div id="confetti-burst"></div>

  <!-- AMBIENT BACKGROUND -->
  <div id="bg-field"></div>

  <main>
    <p class="eyebrow">Туған күніңізбен</p>

    <div id="photo-wrap">
      <div id="photo-frame">
        <div id="photo-inner">
          <div id="photo-placeholder" style="display:none;">
            <span class="ico">🖼️</span>
            <span>Суретті осында қосыңыз</span>
          </div>
          <img id="mom-photo" alt="Анашым" src="data:image/jpeg;base64," style="display:block;">
        </div>
      </div>
      <label id="photo-label" for="photo-input" title="Сурет таңдау">📷</label>
      <input type="file" id="photo-input" accept="image/*">
    </div>

    <h1>Анашым, <span>құттықтаймын!</span></h1>
    <div class="tulip-divider"><span class="line"></span>🌷<span class="line"></span></div>

    <p class="message">
      Дүниедегі ең жақын, ең қымбат, ең қадірлі адамым — <strong>Анашым</strong>! Сізді осы ерекше күнмен шын жүректен,
      шексіз сағынышпен және махаббатпен құттықтаймын. Мен дүниеге келген күннен бастап, әр қадамымда, әр қуанышым мен
      қиындығымда Сіз әрдайым қасымда болдыңыз. Түнде ұйықтамай бесігімді тербеткен, ауырған кезімде түн бойы басымнан
      сипаған, алғашқы қадамымды қуана қарсы алған, мектепке жетектеп апарған — бәрі-бәрі Сіз едіңіз.
    </p>
    <p class="message">
      Сіздің мейіріміңіз бен қайырымдылығыңыз, шыдамдылығыңыз бен даналығыңыз — маған үлгі, маған қорған. Қаншама
      қиындықты өз мойныңызға алып, бізге тек жылуды сыйладыңыз. Осы өмірде Сіздей адал, Сіздей мейірімді жан жоқ
      екенін жүрегіммен сеземін.
    </p>
    <p class="message">
      Бүгін, осы ерекше күні тілейтінім — денсаулығыңыз тау бастындай мықты болсын, көңіліңіз балаша шат болсын,
      көзіңізден шаттық жасы ғана ақсын. Жүзіңіздегі күлкі ешқашан өшпесін, үйіміз бен жүрегіңіз әрдайым қуаныш пен
      махаббатқа толы болсын. Сізге ұзақ ғұмыр, мықты денсаулық және шексіз бақыт тілеймін.
    </p>
    <p class="message">
      Мен Сізді қандай сөзбен жеткізсем де жеткіліксіз болатындай қатты жақсы көремін. Рахмет, Анашым — мені дүниеге
      әкелгеніңізге, мейіріміңізге бөлегеніңізге, мықты да мейірімді адам етіп тәрбиелегеніңізге. Туған күніңіз құтты
      болсын, ардақты Анашым! 💛🌷
    </p>

    <div class="wish-cards">
      <div class="wish-card"><span class="ico">🌹</span><p>Өміріңіз гүлдей әдемі болсын</p></div>
      <div class="wish-card"><span class="ico">✨</span><p>Әр күніңіз бақытқа толы болсын</p></div>
      <div class="wish-card"><span class="ico">💛</span><p>Мейіріміңіз бізге әрдайым жарық берсін</p></div>
      <div class="wish-card"><span class="ico">🕊️</span><p>Денсаулығыңыз мықты, ғұмыр ұзақ болсын</p></div>
    </div>

    <!-- MINI GAME -->
    <div class="game-wrap">
      <div class="game-inner">
        <h2 class="game-title">Қызғалдақ жинау ойыны 🌷</h2>
        <p class="game-sub">Себетті тінтуірмен немесе саусақпен жылжытып, түсіп жатқан гүлдерді ұста!</p>

        <div id="game-stage">
          <div id="basket">🧺</div>
          <div id="game-end">
            <h3>Тамаша, Анашым! 🎉</h3>
            <p id="final-score-text"></p>
            <button id="game-btn" onclick="startGame()">Қайта ойнау</button>
          </div>
        </div>

        <div id="hud">
          <span id="score-line">Ұпай: 0</span>
          <span id="time-line">Уақыт: 30</span>
        </div>
        <button id="start-btn" style="display:block;margin:18px auto 0;" onclick="startGame()">Ойынды бастау</button>
      </div>
    </div>
  </main>

  <footer>
    <span class="signature">Сені шексіз жақсы көретін балаң</span>
    Туған күнің құтты болсын, Анашым! 🌷💛
  </footer>

<script>
/* ================= INTRO CONFETTI BURST ================= */
(function(){
  const burst = document.getElementById('confetti-burst');
  const colors = ['#d8ad55','#f0d698','#f3c7d4','#7a2142','#fbf3ec'];
  const count = 60;
  for(let i=0;i<count;i++){
    const c = document.createElement('div');
    c.className = 'confetti';
    const angle = Math.random()*Math.PI*2;
    const dist = 220 + Math.random()*260;
    const tx = Math.cos(angle)*dist + 'px';
    const ty = Math.sin(angle)*dist - 60 + 'px';
    c.style.setProperty('--tx', tx);
    c.style.setProperty('--ty', ty);
    c.style.setProperty('--rot', (Math.random()*720-360)+'deg');
    c.style.background = colors[Math.floor(Math.random()*colors.length)];
    c.style.animationDelay = (1.0 + Math.random()*0.3) + 's';
    c.style.borderRadius = Math.random() > .5 ? '50%' : '2px';
    burst.appendChild(c);
  }
  setTimeout(()=>{ burst.remove(); document.getElementById('curtain').remove(); }, 3200);
})();

/* ================= AMBIENT BACKGROUND FIELD ================= */
(function(){
  const field = document.getElementById('bg-field');
  const petals = ['🌷','🌸','✨'];
  const total = 26;
  for(let i=0;i<total;i++){
    const el = document.createElement('div');
    const isSpark = Math.random() < .35;
    el.className = isSpark ? 'spark' : 'petal';
    if(!isSpark){
      el.textContent = petals[Math.floor(Math.random()*2)];
      el.style.fontSize = (14 + Math.random()*18) + 'px';
      el.style.opacity = 0.55 + Math.random()*0.35;
    }
    el.style.left = Math.random()*100 + 'vw';
    el.style.setProperty('--drift', (Math.random()*140-70) + 'px');
    el.style.setProperty('--spin', (Math.random()*360) + 'deg');
    const dur = 9 + Math.random()*12;
    el.style.animationDuration = dur + 's';
    el.style.animationDelay = (-Math.random()*dur) + 's';
    field.appendChild(el);
  }
})();

/* ================= PHOTO UPLOAD ================= */
(function(){
  const input = document.getElementById('photo-input');
  const img = document.getElementById('mom-photo');
  const placeholder = document.getElementById('photo-placeholder');
  input.addEventListener('change', function(){
    const file = this.files && this.files[0];
    if(!file) return;
    const reader = new FileReader();
    reader.onload = function(e){
      img.src = e.target.result;
      img.style.display = 'block';
      placeholder.style.display = 'none';
    };
    reader.readAsDataURL(file);
  });
})();

/* ================= MINI GAME: ҚЫЗҒАЛДАҚ ЖИНАУ ================= */
const stage = document.getElementById('game-stage');
const basket = document.getElementById('basket');
const scoreLine = document.getElementById('score-line');
const timeLine = document.getElementById('time-line');
const startBtn = document.getElementById('start-btn');
const gameEnd = document.getElementById('game-end');
const finalScoreText = document.getElementById('final-score-text');

let score = 0, timeLeft = 30, gameRunning = false;
let basketX = 260, spawnInterval, timerInterval, fallItems = [];

function moveBasket(clientX){
  const rect = stage.getBoundingClientRect();
  let x = clientX - rect.left;
  x = Math.max(30, Math.min(rect.width-30, x));
  basketX = x;
  basket.style.left = x + 'px';
}
stage.addEventListener('mousemove', e => { if(gameRunning) moveBasket(e.clientX); });
stage.addEventListener('touchmove', e => {
  if(gameRunning){ moveBasket(e.touches[0].clientX); e.preventDefault(); }
}, {passive:false});

function spawnItem(){
  const rect = stage.getBoundingClientRect();
  const el = document.createElement('div');
  el.className = 'falling';
  const isGold = Math.random() < 0.15;
  el.textContent = isGold ? '⭐' : (Math.random() < 0.5 ? '🌷' : '🌸');
  el.dataset.value = isGold ? 5 : 1;
  const startX = 20 + Math.random()*(rect.width-40);
  el.style.left = startX + 'px';
  el.style.top = '-30px';
  stage.appendChild(el);
  fallItems.push({el, x:startX, y:-30, speed: 1.6 + Math.random()*1.8, value: parseInt(el.dataset.value)});
}

function gameLoop(){
  if(!gameRunning) return;
  const rect = stage.getBoundingClientRect();
  for(let i=fallItems.length-1;i>=0;i--){
    const item = fallItems[i];
    item.y += item.speed;
    item.el.style.top = item.y + 'px';

    const caught = item.y > rect.height-60 && item.y < rect.height-10 && Math.abs(item.x - basketX) < 34;
    if(caught){
      score += item.value;
      scoreLine.textContent = 'Ұпай: ' + score;
      item.el.remove();
      fallItems.splice(i,1);
      continue;
    }
    if(item.y > rect.height+20){
      item.el.remove();
      fallItems.splice(i,1);
    }
  }
  requestAnimationFrame(gameLoop);
}

function startGame(){
  score = 0; timeLeft = 30; gameRunning = true;
  scoreLine.textContent = 'Ұпай: 0';
  timeLine.textContent = 'Уақыт: 30';
  gameEnd.style.display = 'none';
  startBtn.style.display = 'none';
  fallItems.forEach(i => i.el.remove());
  fallItems = [];
  basket.style.left = '260px';

  clearInterval(spawnInterval); clearInterval(timerInterval);
  spawnInterval = setInterval(spawnItem, 650);
  timerInterval = setInterval(() => {
    timeLeft--;
    timeLine.textContent = 'Уақыт: ' + timeLeft;
    if(timeLeft <= 0) endGame();
  }, 1000);

  requestAnimationFrame(gameLoop);
}

function endGame(){
  gameRunning = false;
  clearInterval(spawnInterval); clearInterval(timerInterval);
  fallItems.forEach(i => i.el.remove());
  fallItems = [];
  let msg;
  if(score >= 25) msg = 'Керемет! Сіз нағыз гүл ұстаушысыз! 🌷💛';
  else if(score >= 12) msg = 'Жақсы ойнадыңыз! Тағы бір рет байқап көріңіз 🌸';
  else msg = 'Жаман емес! Қайта ойнап, жоғары ұпай жинап көріңіз ✨';
  finalScoreText.textContent = 'Жиналған ұпай: ' + score + '. ' + msg;
  gameEnd.style.display = 'flex';
}
</script>
</body>
</html>
